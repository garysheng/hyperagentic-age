{
  "id": "thank-you-card",
  "version": "1.0.0",
  "extends": "share-card@1.0.0",
  "author": "agenticbranduniverse.com/registry",
  "description": "A personal card. Forks share-card: same two-panel structure, different surface and a named recipient.",
  "surface": {
    "medium": "raster",
    "geometry": {
      "w": 1500,
      "h": 900,
      "split": 900
    }
  },
  "requires": [
    {
      "kind": "style-pack",
      "min": 1
    }
  ],
  "slots": [
    {
      "id": "text-panel",
      "type": "deterministic",
      "schema": {
        "recipient": "string",
        "body": "string",
        "signoff": "string"
      },
      "emitter": "agenticstory:brand-card"
    },
    {
      "id": "art-panel",
      "type": "generated",
      "geometry": {
        "w": 600,
        "h": 900
      }
    }
  ],
  "generators": [
    {
      "for": "art-panel",
      "capability": "image",
      "accepts": "reference-images",
      "pin": "gpt-image-2",
      "producibleAspects": [
        1.0,
        0.667,
        1.5
      ],
      "tolerance": 0.25
    }
  ],
  "invariants": {
    "perSlot": [
      {
        "id": "no-text-in-art",
        "check": "judged"
      },
      {
        "id": "flat: no perspective, shading, gradients, or coloured linework",
        "check": "judged"
      },
      {
        "id": "recipient name spelled exactly as bound",
        "check": "computed"
      }
    ],
    "crossSlot": []
  },
  "emits": [
    "thank-you-<recipient>.webp"
  ],
  "notes": "Surface is 5:3 rather than square because the art panel must land on a producible aspect. A 1200x1200 card with a two-thirds split needs 0.333, which no generator emits."
}
