{
  "id": "flyer",
  "version": "1.0.0",
  "extends": null,
  "author": "agenticbranduniverse.com/registry",
  "description": "A single-surface promotional sheet: headline, art, body, and a footer mark. First projection with a genuine cross-slot rule.",
  "surface": {
    "medium": "raster-or-pdf",
    "geometry": {
      "aspect": "A4 portrait"
    }
  },
  "requires": [
    {
      "kind": "style-pack",
      "min": 1
    },
    {
      "kind": "motif",
      "min": 0
    }
  ],
  "slots": [
    {
      "id": "headline",
      "type": "deterministic",
      "emitter": "agenticstory:brand-card"
    },
    {
      "id": "hero",
      "type": "generated"
    },
    {
      "id": "body",
      "type": "deterministic",
      "emitter": "agenticstory:brand-card"
    },
    {
      "id": "mark",
      "type": "deterministic",
      "emitter": "agenticstory:brand-card"
    }
  ],
  "generators": [
    {
      "for": "hero",
      "capability": "image",
      "accepts": "reference-images",
      "pin": "gpt-image-2",
      "producibleAspects": [
        1.0,
        0.667,
        1.5
      ],
      "tolerance": 0.25,
      "quirks": [
        {
          "id": "artwork-within-artwork-renders-inverted",
          "seen": "When a person is depicted drawing, holding, or displaying a picture, the depicted picture renders upside down relative to the viewer.",
          "counter": "Any picture, page, book, drawing, or artwork shown INSIDE the scene must be RIGHT SIDE UP and correctly oriented to the viewer. Never inverted, never rotated, never upside down.",
          "check": "judged",
          "provider": "gpt-image-2",
          "observedBy": "gary",
          "observedOn": "2026-07-23"
        }
      ]
    },
    {
      "for": "body",
      "capability": "text",
      "optional": true
    }
  ],
  "invariants": {
    "perSlot": [
      {
        "id": "no-text-in-art",
        "check": "judged"
      },
      {
        "id": "flat: no perspective, shading, gradients, or coloured linework",
        "check": "judged"
      },
      {
        "id": "palette-only",
        "check": "computed"
      }
    ],
    "crossSlot": [
      {
        "id": "one visual voice across hero and mark: the same palette and line weight",
        "check": "judged",
        "scope": "hero + mark"
      }
    ]
  },
  "emits": [
    "flyer-<name>.pdf",
    "flyer-<name>.webp"
  ]
}
